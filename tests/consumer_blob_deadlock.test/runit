#!/usr/bin/env bash
bash -n "$0" || exit 1

source ${TESTSROOTDIR}/tools/runit_common.sh

set -e

cdb2sql="${CDB2SQL_EXE} ${CDB2_OPTIONS} ${DBNAME} default"
cdb2sql_tabs="${CDB2SQL_EXE} --tabs ${CDB2_OPTIONS} ${DBNAME} default"

# Create table with blob columns
${cdb2sql} "create table t(i int, b blob)"

# Create a default consumer on updates (and inserts for the initial row)
${cdb2sql} "create default lua consumer blobcons on (table t for update)"

# Insert a row with a known blob value
${cdb2sql} "insert into t values(1, x'deadbeef')"

# Enable the tunable to simulate deadlock in save_old_blobs
# for the new record's blobs in the trigger path
sendtocluster "exec procedure sys.cmd.send('test_trigger_deadlock 1')"

# Update the row — with the bug, the trigger event will have empty blobs
# for the new record
${cdb2sql} "update t set b = x'cafebabe' where i = 1"

# Disable the tunable
sendtocluster "exec procedure sys.cmd.send('test_trigger_deadlock 0')"

# Consume the update event — emits 'old' and 'new' rows
out=$(${cdb2sql_tabs} "exec procedure blobcons('{\"with_id\":false, \"consume_count\":1}')")
echo "$out"

# In --tabs mode, the 'new' row looks like: new\t1\tx'cafebabe'
# With the bug, the blob would be empty: new\t1\tx''
new_blob=$(echo "$out" | grep "^new" | awk -F'\t' '{print $NF}')
echo "new blob: $new_blob"

if [ "$new_blob" = "x'cafebabe'" ]; then
    echo "PASS: blob delivered correctly in update event"
else
    echo "FAIL: blob missing or incorrect in update event"
    echo "expected x'cafebabe', got $new_blob"
    exit 1
fi

echo "passed consumer_blob_deadlock"
