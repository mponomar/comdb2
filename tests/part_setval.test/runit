#!/usr/bin/env bash
bash -n "$0" | exit 1

# Test input validation for SET PARTITION NUMDBS / NUMCOLS / DBS / COLS / SHARDS.
# Regression test for crash: SET PARTITION NUMDBS <huge> followed by SET PARTITION DBS x
# caused a NULL-pointer dereference when malloc failed for the huge allocation.

source ${TESTSROOTDIR}/tools/runit_common.sh

dbnm=$1

if [ "x$dbnm" == "x" ]; then
    failexit "need a DB name"
fi

# Run a SET + SELECT pair.  The SET commands are buffered client-side and sent to
# the server together with the SELECT; a bad SET value causes the SELECT to fail
# with the validation error.  Capture both stdout and stderr.
run_set_select() {
    cdb2sql ${CDB2_OPTIONS} -s "$dbnm" default - 2>&1 <<EOF
$1
select 1
EOF
}

# ---------------------------------------------------------------------------
# 1. NUMDBS above the allowed ceiling (4096) must be rejected with an error.
# ---------------------------------------------------------------------------
out=$(run_set_select "set PARTITION NUMDBS 2147483647")
rc=$?
if [ $rc -eq 0 ]; then
    failexit "Expected failure for NUMDBS=2147483647 but got success"
fi
if ! echo "$out" | grep -qi "bad value for PARTITION NUMDBS"; then
    failexit "Expected 'bad value for PARTITION NUMDBS' error, got: $out"
fi

# Zero is also invalid (must be > 0).
out=$(run_set_select "set PARTITION NUMDBS 0")
rc=$?
if [ $rc -eq 0 ]; then
    failexit "Expected failure for NUMDBS=0 but got success"
fi
if ! echo "$out" | grep -qi "bad value for PARTITION NUMDBS"; then
    failexit "Expected 'bad value for PARTITION NUMDBS' error for 0, got: $out"
fi

# ---------------------------------------------------------------------------
# 2. NUMCOLS above the allowed ceiling (4096) must be rejected.
# ---------------------------------------------------------------------------
out=$(run_set_select "set PARTITION NUMCOLS 2147483647")
rc=$?
if [ $rc -eq 0 ]; then
    failexit "Expected failure for NUMCOLS=2147483647 but got success"
fi
if ! echo "$out" | grep -qi "bad value for PARTITION NUMCOLS"; then
    failexit "Expected 'bad value for PARTITION NUMCOLS' error, got: $out"
fi

# ---------------------------------------------------------------------------
# 3. The original crash sequence must not kill the server.
#    Before the fix: NUMDBS=2147483647 caused malloc(~16 GB) to return NULL,
#    and the subsequent SET PARTITION DBS write to that NULL pointer crashed.
# ---------------------------------------------------------------------------
cdb2sql ${CDB2_OPTIONS} -s "$dbnm" default - 2>&1 <<'EOF'
set PARTITION NUMDBS 2147483647
set PARTITION DBS x
select 1
EOF
# We don't check the exit code here — we only care that the server survives.

# ---------------------------------------------------------------------------
# 4. Server must still be reachable after all the invalid input above.
# ---------------------------------------------------------------------------
out=$(cdb2sql -tabs ${CDB2_OPTIONS} "$dbnm" default "select 1" 2>&1)
rc=$?
if [ $rc -ne 0 ]; then
    failexit "Server is no longer reachable after invalid SET inputs: $out"
fi
assertres "$out" "1" "server should still respond after bad SET commands"

# ---------------------------------------------------------------------------
# 5. Valid NUMDBS (within range) must be accepted without error.
# ---------------------------------------------------------------------------
out=$(run_set_select "set PARTITION NUMDBS 2")
rc=$?
if [ $rc -ne 0 ]; then
    failexit "Expected success for valid NUMDBS=2 but got failure: $out"
fi

# ---------------------------------------------------------------------------
# 6. Valid NUMCOLS (within range) must be accepted without error.
# ---------------------------------------------------------------------------
out=$(run_set_select "set PARTITION NUMCOLS 4")
rc=$?
if [ $rc -ne 0 ]; then
    failexit "Expected success for valid NUMCOLS=4 but got failure: $out"
fi

echo "Testcase passed."
