#!/usr/bin/env bash
# Regression test for heap-buffer-overflow in key_add_comn (macc_so.c).
#
# ixflags[] in macc_globals_t is sized to MAXINDEX (50), but the index number
# (ix) is derived from keyixnum[] which is sized to MAXKEYS (256).  Creating a
# table with more than MAXINDEX keys caused an out-of-bounds write to
# ixflags[ix] when ix >= MAXINDEX, crashing the server.
#
# The fix adds a bounds check in key_add_comn so that schemas with too many
# indexes are rejected with a proper error and the server stays alive.
#
# Test plan:
#   1. CREATE TABLE with exactly 50 keys (at the limit) -- must succeed.
#   2. ALTER TABLE to add a 51st key -- must be rejected, server stays alive.
#   3. CREATE TABLE with 256 keys -- must be rejected, server stays alive.

bash -n "$0" | exit 1

source ${TESTSROOTDIR}/tools/runit_common.sh
set -x

if [[ -z "$DBNAME" ]]; then
    echo "DBNAME not set"
    exit 1
fi

# --- 1. CREATE TABLE with exactly 50 keys (should succeed) ---
$CDB2SQL_EXE ${CDB2_OPTIONS} $DBNAME default "create table t50 { `cat t50.csc2` }"
if [[ $? -ne 0 ]]; then
    failexit "CREATE TABLE t50 with 50 keys (at the limit) failed"
fi

# --- 2. ALTER TABLE to add a 51st key (should be rejected) ---
$CDB2SQL_EXE ${CDB2_OPTIONS} $DBNAME default "alter table t50 { `cat t51.csc2` }"
if [[ $? -eq 0 ]]; then
    failexit "ALTER TABLE t50 to 51 keys should have been rejected"
fi

$CDB2SQL_EXE ${CDB2_OPTIONS} $DBNAME default "select 1"
if [[ $? -ne 0 ]]; then
    failexit "Server is unresponsive after rejecting ALTER TABLE with 51 keys"
fi

# --- 3. CREATE TABLE with 256 keys (should be rejected) ---
$CDB2SQL_EXE ${CDB2_OPTIONS} $DBNAME default "create table crash256 { `cat crash256.csc2` }"
if [[ $? -eq 0 ]]; then
    failexit "CREATE TABLE crash256 with 256 keys should have been rejected"
fi

$CDB2SQL_EXE ${CDB2_OPTIONS} $DBNAME default "select 1"
if [[ $? -ne 0 ]]; then
    failexit "Server is unresponsive after rejecting CREATE TABLE with 256 keys"
fi

echo "Testcase passed."
exit 0
