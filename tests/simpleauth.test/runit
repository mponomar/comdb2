#!/usr/bin/env bash
bash -n "$0" | exit 1

set -e
source ${TESTSROOTDIR}/tools/runit_common.sh

dbnm=$1

if [ "x$dbnm" == "x" ] ; then
    failexit "need a DB name"
fi

SA="${TESTSBUILDDIR}/simpleauth_test ${dbnm}"
OP="bpi:procauth:cluster:test:user:op:bpkg:setup"
MOHIT="bpi:procauth:cluster:testcluster:user:mohit:bpkg:myapp"
MIKE="bpi:procauth:cluster:prod:user:mike:bpkg:cdb2sql"
MARK="bpi:procauth:cluster:test:user:mk:bpkg:myapp"

passed=0
failed=0

run_expect_success() {
    local principal="$1"
    local sql="$2"
    local desc="$3"
    if $SA "$principal" "$sql" > /dev/null 2>&1; then
        echo "  PASS: $desc"
        passed=$((passed + 1))
    else
        echo "  FAIL: $desc"
        failed=$((failed + 1))
    fi
}

run_expect_output() {
    local principal="$1"
    local sql="$2"
    local expected="$3"
    local desc="$4"
    local actual
    actual=$($SA "$principal" "$sql" 2>/dev/null)
    if [ "$actual" = "$expected" ]; then
        echo "  PASS: $desc"
        passed=$((passed + 1))
    else
        echo "  FAIL: $desc (expected '$expected', got '$actual')"
        failed=$((failed + 1))
    fi
}

run_expect_failure() {
    local principal="$1"
    local sql="$2"
    local desc="$3"
    if $SA "$principal" "$sql" > /dev/null 2>&1; then
        echo "  FAIL: $desc (expected failure but succeeded)"
        failed=$((failed + 1))
    else
        echo "  PASS: $desc"
        passed=$((passed + 1))
    fi
}

#---------------------------------------------------------------
echo "Test: setup comdb2_simple_auth table"
#---------------------------------------------------------------
run_expect_success "$OP" "create table if not exists comdb2_simple_auth(cluster cstring(20) default '*', user cstring(20) default '*', bpkg cstring(50) default '*', verb cstring(20) default '*', resourcetype cstring(20) default '*', resourcename cstring(50) default '*')" \
    "create auth table"
run_expect_success "$OP" "create unique index if not exists comdb2_simple_auth_ix on comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename)" \
    "create auth index"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', '*', '*', '*') on conflict do nothing" \
    "insert wildcard rule"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', 'Connect', '*', '*') on conflict do nothing" \
    "insert Connect rule"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', 'Read', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "insert Read rule for auth table"

#---------------------------------------------------------------
echo "Test: principal parsing with different identities"
#---------------------------------------------------------------
run_expect_success "$OP" "create table if not exists t1(i int)" \
    "create test table t1"
run_expect_success "$OP" "insert into t1 values(1)" \
    "insert into t1"
run_expect_success "$MOHIT" "select * from t1" \
    "mohit can read t1 (wildcard allows)"
run_expect_success "$MIKE" "select * from t1" \
    "mike can read t1 (wildcard allows)"

#---------------------------------------------------------------
echo "Test: restricted access after removing wildcard"
#---------------------------------------------------------------
# Grant op access to auth table before removing wildcard
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Write', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op write on auth table"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Read', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op read on auth table"
run_expect_success "$OP" "delete from comdb2_simple_auth where cluster='*' and user='*' and bpkg='*' and verb='*' and resourcetype='*' and resourcename='*'" \
    "remove wildcard rule"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mohit', '*', 'Read', 'table', 't1') on conflict do nothing" \
    "add mohit Read rule for t1"

run_expect_success "$MOHIT" "select * from t1" \
    "mohit can read t1 (specific rule)"
run_expect_failure "$MIKE" "select * from t1" \
    "mike cannot read t1 (no matching rule)"

# Restore
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', '*', '*', '*') on conflict do nothing" \
    "restore wildcard rule"
run_expect_success "$OP" "delete from comdb2_simple_auth where user = 'op' or user = 'mohit'" \
    "clean up user-specific rules"

#---------------------------------------------------------------
echo "Test: verb-specific permissions (Read vs Write)"
#---------------------------------------------------------------
# Grant op access to auth table before removing wildcard
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Write', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op write on auth table"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Read', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op read on auth table"
run_expect_success "$OP" "delete from comdb2_simple_auth where cluster='*' and user='*' and bpkg='*' and verb='*' and resourcetype='*' and resourcename='*'" \
    "remove wildcard rule"

# mk gets Read-only on t1
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mk', '*', 'Read', 'table', 't1') on conflict do nothing" \
    "add mk Read rule for t1"
run_expect_success "$MARK" "select * from t1" \
    "mk can read t1"
run_expect_failure "$MARK" "insert into t1 values(2)" \
    "mk cannot write t1 (no Write rule)"

# Now grant mk Write
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mk', '*', 'Write', 'table', 't1') on conflict do nothing" \
    "add mk Write rule for t1"
run_expect_success "$MARK" "insert into t1 values(2)" \
    "mk can write t1 (Write rule added)"

# Restore
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', '*', '*', '*') on conflict do nothing" \
    "restore wildcard rule"
run_expect_success "$OP" "delete from comdb2_simple_auth where user != '*'" \
    "clean up user-specific rules"

#---------------------------------------------------------------
echo "Test: UDF access bypasses simpleauth, stored procedures do not"
#---------------------------------------------------------------

# Create procedures and register UDFs while wildcard allows it
run_expect_success "$OP" "create procedure myadd version 'test' {local function myadd(a, b) return a + b end}" \
    "create myadd procedure for scalar UDF"
run_expect_success "$OP" "create lua scalar function myadd" \
    "register myadd as scalar UDF"
run_expect_success "$OP" "create procedure mysum version 'test' {local agg = 0 local function step(v) agg = agg + v end local function final() return agg end}" \
    "create mysum procedure for aggregate UDF"
run_expect_success "$OP" "create lua aggregate function mysum" \
    "register mysum as aggregate UDF"
run_expect_success "$OP" "create procedure myproc version 'test' {local function main() db:column_name('result', 1) db:column_type('text', 1) db:emit('hello') end}" \
    "create myproc stored procedure"
run_expect_success "$OP" "create table if not exists t_udf(i int)" \
    "create t_udf table"
run_expect_success "$OP" "insert into t_udf values(10),(20),(30)" \
    "populate t_udf"

# Verify everything works with wildcard in place
run_expect_success "$MARK" "select myadd(1, 2)" \
    "mk can call scalar UDF (wildcard allows)"
run_expect_success "$MARK" "select mysum(i) from t_udf" \
    "mk can call aggregate UDF (wildcard allows)"
run_expect_success "$MARK" "exec procedure myproc()" \
    "mk can exec procedure (wildcard allows)"

# Set up restricted access: remove wildcard, grant mk only table access
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Write', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op write on auth table"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Read', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op read on auth table"
run_expect_success "$OP" "delete from comdb2_simple_auth where cluster='*' and user='*' and bpkg='*' and verb='*' and resourcetype='*' and resourcename='*'" \
    "remove wildcard rule"

# Give mk Read access to t_udf table only (no stored-procedure access)
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mk', '*', 'Read', 'table', 't_udf') on conflict do nothing" \
    "add mk Read rule for t_udf"

# mk can call scalar UDF (no table involved, UDFs bypass auth entirely)
run_expect_success "$MARK" "select myadd(1, 2)" \
    "mk can call scalar UDF without stored-procedure access (UDFs bypass auth)"

# mk can call aggregate UDF on t_udf (table Read is enough, UDF itself needs no auth)
run_expect_success "$MARK" "select mysum(i) from t_udf" \
    "mk can call aggregate UDF with table access (UDFs bypass auth)"

# mk cannot exec stored procedure (stored procedures check auth, no matching rule)
run_expect_failure "$MARK" "exec procedure myproc()" \
    "mk cannot exec procedure without stored-procedure Read rule"

# Restore and cleanup
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', '*', '*', '*') on conflict do nothing" \
    "restore wildcard rule"
run_expect_success "$OP" "delete from comdb2_simple_auth where user = 'op' or user = 'mk'" \
    "clean up user-specific rules"
run_expect_success "$OP" "drop lua scalar function myadd" \
    "drop myadd UDF"
run_expect_success "$OP" "drop lua aggregate function mysum" \
    "drop mysum UDF"
run_expect_success "$OP" "drop procedure myadd version 'test'" \
    "drop myadd procedure"
run_expect_success "$OP" "drop procedure mysum version 'test'" \
    "drop mysum procedure"
run_expect_success "$OP" "drop procedure myproc version 'test'" \
    "drop myproc procedure"
run_expect_success "$OP" "drop table if exists t_udf" \
    "drop t_udf table"

#---------------------------------------------------------------
echo "Test: vtab access control with externalauth (CDB2_ALLOW_ALL)"
#---------------------------------------------------------------
# CDB2_ALLOW_ALL vtabs should be accessible to any authenticated user
# regardless of specific permissions, since comdb2_check_vtab_access
# returns SQLITE_OK immediately for these modules.
run_expect_success "$MOHIT" "select 1 from comdb2_tables limit 1" \
    "mohit can access comdb2_tables (CDB2_ALLOW_ALL)"
run_expect_success "$MIKE" "select 1 from comdb2_columns limit 1" \
    "mike can access comdb2_columns (CDB2_ALLOW_ALL)"
run_expect_success "$MARK" "select 1 from comdb2_keywords limit 1" \
    "mk can access comdb2_keywords (CDB2_ALLOW_ALL)"
run_expect_success "$MOHIT" "select 1 from comdb2_cluster limit 1" \
    "mohit can access comdb2_cluster (CDB2_ALLOW_ALL)"

#---------------------------------------------------------------
echo "Test: vtab access control with externalauth (CDB2_ALLOW_USER, wildcard)"
#---------------------------------------------------------------
# CDB2_ALLOW_USER vtabs should be accessible when a wildcard
# permission rule is in place.
run_expect_success "$MOHIT" "select 1 from comdb2_tunables limit 1" \
    "mohit can access comdb2_tunables (wildcard allows)"
run_expect_success "$MIKE" "select 1 from comdb2_metrics limit 1" \
    "mike can access comdb2_metrics (wildcard allows)"
run_expect_success "$MARK" "select 1 from comdb2_connections limit 1" \
    "mk can access comdb2_connections (wildcard allows)"
run_expect_success "$MOHIT" "select 1 from comdb2_files limit 1" \
    "mohit can access comdb2_files (wildcard allows)"

#---------------------------------------------------------------
echo "Test: vtab access denied without matching permission"
#---------------------------------------------------------------
# Remove wildcard rule and verify CDB2_ALLOW_USER vtabs are denied
# for users without specific permission.
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Write', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op write on auth table (vtab test)"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Read', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op read on auth table (vtab test)"
run_expect_success "$OP" "delete from comdb2_simple_auth where cluster='*' and user='*' and bpkg='*' and verb='*' and resourcetype='*' and resourcename='*'" \
    "remove wildcard rule (vtab test)"

# CDB2_ALLOW_USER vtabs (non-strict) are allowed in non-strict mode
run_expect_success "$MOHIT" "select 1 from comdb2_tunables limit 1" \
    "mohit can access comdb2_tunables (non-strict, no matching rule)"
run_expect_success "$MIKE" "select 1 from comdb2_metrics limit 1" \
    "mike can access comdb2_metrics (non-strict, no matching rule)"

# CDB2_STRICT vtabs should be denied without matching permission
run_expect_failure "$MARK" "select 1 from comdb2_connections limit 1" \
    "mk cannot access comdb2_connections (CDB2_STRICT, no matching rule)"
run_expect_failure "$MOHIT" "select 1 from comdb2_files limit 1" \
    "mohit cannot access comdb2_files (CDB2_STRICT, no matching rule)"

# CDB2_ALLOW_ALL vtabs should still be accessible without any permission
run_expect_success "$MOHIT" "select 1 from comdb2_tables limit 1" \
    "mohit can still access comdb2_tables (CDB2_ALLOW_ALL, no wildcard)"
run_expect_success "$MIKE" "select 1 from comdb2_keywords limit 1" \
    "mike can still access comdb2_keywords (CDB2_ALLOW_ALL, no wildcard)"

#---------------------------------------------------------------
echo "Test: vtab access granted with specific permission"
#---------------------------------------------------------------
# Grant mohit specific Read access to comdb2_connections (CDB2_STRICT)
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mohit', '*', 'Read', 'table', 'comdb2_connections') on conflict do nothing" \
    "grant mohit Read on comdb2_connections"
run_expect_success "$MOHIT" "select 1 from comdb2_connections limit 1" \
    "mohit can access comdb2_connections (specific rule)"
# mike still denied (no rule for him, CDB2_STRICT)
run_expect_failure "$MIKE" "select 1 from comdb2_connections limit 1" \
    "mike still cannot access comdb2_connections (CDB2_STRICT, no rule)"

# Grant mike specific Read access to comdb2_files (CDB2_STRICT)
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mike', '*', 'Read', 'table', 'comdb2_files') on conflict do nothing" \
    "grant mike Read on comdb2_files"
run_expect_success "$MIKE" "select 1 from comdb2_files limit 1" \
    "mike can access comdb2_files (specific rule)"
# mohit still denied (no rule for her, CDB2_STRICT)
run_expect_failure "$MOHIT" "select 1 from comdb2_files limit 1" \
    "mohit still cannot access comdb2_files (CDB2_STRICT, no rule)"

# Restore wildcard and clean up vtab-specific rules
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', '*', '*', '*') on conflict do nothing" \
    "restore wildcard rule (vtab test)"
run_expect_success "$OP" "delete from comdb2_simple_auth where user != '*'" \
    "clean up user-specific rules (vtab test)"

#---------------------------------------------------------------
echo "Test: anonymous access"
#---------------------------------------------------------------
ANON="bpi:anonymous"

run_expect_success "$ANON" "select * from t1" \
    "anonymous can read t1 (wildcard allows)"

# Remove wildcard, grant op access to auth table
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Write', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op write on auth table"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Read', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op read on auth table"
run_expect_success "$OP" "delete from comdb2_simple_auth where cluster='*' and user='*' and bpkg='*' and verb='*' and resourcetype='*' and resourcename='*'" \
    "remove wildcard rule"

run_expect_failure "$ANON" "select * from t1" \
    "anonymous cannot read t1 (no matching rule)"

# Restore
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', '*', '*', '*') on conflict do nothing" \
    "restore wildcard rule"
run_expect_success "$OP" "delete from comdb2_simple_auth where user = 'op'" \
    "clean up op rules"

#---------------------------------------------------------------
echo "Test: verify simpleauth logs driver_name in client_info for anonymous"
#---------------------------------------------------------------
found_log=0
if [ -n "$CLUSTER" ] ; then
    for node in $(getclusternodes) ; do
        logfile="${TESTDIR}/logs/${dbnm}.${node}.db"
        if grep -q "simpleauth: principal='bpi:anonymous' client_info='.*:driver_name:" "$logfile" 2>/dev/null; then
            found_log=1
            break
        fi
    done
else
    logfile="${TESTDIR}/logs/${dbnm}.db"
    if grep -q "simpleauth: principal='bpi:anonymous' client_info='.*:driver_name:" "$logfile" 2>/dev/null; then
        found_log=1
    fi
fi
if [ $found_log -eq 1 ]; then
    echo "  PASS: server log shows anonymous principal with driver_name in client_info"
    passed=$((passed + 1))
else
    echo "  FAIL: server log missing driver_name in anonymous client_info"
    failed=$((failed + 1))
fi

#---------------------------------------------------------------
echo "Test: allow_old_authn with parallel SQL (dohsql)"
#---------------------------------------------------------------
# This tests that auth reuse on the same connection works correctly
# with parallel SQL (UNION ALL triggers dohsql sharding).

run_expect_success "$OP" "create table if not exists t_par1(i int)" \
    "create t_par1"
run_expect_success "$OP" "create table if not exists t_par2(i int)" \
    "create t_par2"
run_expect_success "$OP" "create table if not exists t_par3(i int)" \
    "create t_par3"
run_expect_success "$OP" "insert into t_par1 values(1),(2),(3)" \
    "populate t_par1"
run_expect_success "$OP" "insert into t_par2 values(4),(5),(6)" \
    "populate t_par2"
run_expect_success "$OP" "insert into t_par3 values(7),(8),(9)" \
    "populate t_par3"

# Run parallel SQL (UNION ALL) with wildcard access — exercises dohsql + auth reuse
run_expect_success "$MOHIT" \
    "select i from t_par1 union all select i from t_par2 union all select i from t_par3" \
    "mohit parallel SQL with wildcard"

# Run multiple queries on same connection — exercises allow_old_authn auth reuse
run_multi_expect_success() {
    local principal="$1"
    local desc="$2"
    shift 2
    if $SA "$principal" "$@" > /dev/null 2>&1; then
        echo "  PASS: $desc"
        passed=$((passed + 1))
    else
        echo "  FAIL: $desc"
        failed=$((failed + 1))
    fi
}

run_multi_expect_success "$MOHIT" \
    "mohit multi-query auth reuse with parallel SQL" \
    "select i from t_par1" \
    "select i from t_par2" \
    "select i from t_par1 union all select i from t_par2 union all select i from t_par3"

# Run queries inside a transaction — triggers oldAuthnResult caching
run_multi_expect_success "$MOHIT" \
    "mohit transaction auth reuse with parallel SQL" \
    "begin" \
    "select i from t_par1" \
    "select i from t_par2" \
    "select i from t_par1 union all select i from t_par2 union all select i from t_par3" \
    "commit"

# Same test under restricted access
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Write', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op write on auth table"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'op', '*', 'Read', 'table', 'comdb2_simple_auth') on conflict do nothing" \
    "grant op read on auth table"
run_expect_success "$OP" "delete from comdb2_simple_auth where cluster='*' and user='*' and bpkg='*' and verb='*' and resourcetype='*' and resourcename='*'" \
    "remove wildcard rule"

# Grant mohit Read on all three tables
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mohit', '*', 'Read', 'table', 't_par1') on conflict do nothing" \
    "grant mohit Read on t_par1"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mohit', '*', 'Read', 'table', 't_par2') on conflict do nothing" \
    "grant mohit Read on t_par2"
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', 'mohit', '*', 'Read', 'table', 't_par3') on conflict do nothing" \
    "grant mohit Read on t_par3"

# Parallel SQL under restricted access — exercises dohsql + auth reuse + access checks
run_expect_success "$MOHIT" \
    "select i from t_par1 union all select i from t_par2 union all select i from t_par3" \
    "mohit parallel SQL with restricted access"

# Multi-query auth reuse under restricted access
run_multi_expect_success "$MOHIT" \
    "mohit multi-query auth reuse with restricted access" \
    "select i from t_par1" \
    "select i from t_par2" \
    "select i from t_par1 union all select i from t_par2 union all select i from t_par3"

# Transaction auth reuse under restricted access
run_multi_expect_success "$MOHIT" \
    "mohit transaction auth reuse with restricted access" \
    "begin" \
    "select i from t_par1" \
    "select i from t_par2" \
    "select i from t_par1 union all select i from t_par2 union all select i from t_par3" \
    "commit"

# mike has no access — parallel SQL should fail
run_expect_failure "$MIKE" \
    "select i from t_par1 union all select i from t_par2 union all select i from t_par3" \
    "mike parallel SQL denied (no matching rule)"

# Restore
run_expect_success "$OP" "insert into comdb2_simple_auth(cluster, user, bpkg, verb, resourcetype, resourcename) values('*', '*', '*', '*', '*', '*') on conflict do nothing" \
    "restore wildcard rule"
run_expect_success "$OP" "delete from comdb2_simple_auth where user = 'op' or user = 'mohit'" \
    "clean up user-specific rules"

#---------------------------------------------------------------
echo "Test: comdb2_user() returns external auth principal"
#---------------------------------------------------------------
run_expect_output "$MOHIT" "select comdb2_user()" \
    "(comdb2_user()='bpi:procauth:cluster:testcluster:user:mohit:bpkg:myapp')" \
    "comdb2_user() returns mohit principal"
run_expect_output "$MIKE" "select comdb2_user()" \
    "(comdb2_user()='bpi:procauth:cluster:prod:user:mike:bpkg:cdb2sql')" \
    "comdb2_user() returns mike principal"
run_expect_output "$MARK" "select comdb2_user()" \
    "(comdb2_user()='bpi:procauth:cluster:test:user:mk:bpkg:myapp')" \
    "comdb2_user() returns mark principal"

#---------------------------------------------------------------
echo "Test: cleanup"
#---------------------------------------------------------------
run_expect_success "$OP" "drop table if exists t_par1" \
    "drop t_par1"
run_expect_success "$OP" "drop table if exists t_par2" \
    "drop t_par2"
run_expect_success "$OP" "drop table if exists t_par3" \
    "drop t_par3"
run_expect_success "$OP" "drop table if exists t1" \
    "drop test table"

