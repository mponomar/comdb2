#!/usr/bin/env bash
bash -n "$0" | exit 1
set -x

output=run.log

DBNAME=$1
[[ -z "$DBNAME" ]] && { echo "Usage: $0 <dbname>"; exit 1; }
shift

${CDB2SQL_EXE} ${CDB2_OPTIONS} ${DBNAME} default "create table t { $(cat t.csc2) }"
${CDB2SQL_EXE} ${CDB2_OPTIONS} ${DBNAME} default "delete from comdb2_simple_auth where verb='*'"
master=$(${CDB2SQL_EXE} ${CDB2_OPTIONS} --tabs ${DBNAME} default "select host from comdb2_cluster where is_master='Y'")

${TESTSBUILDDIR}/gen_all_blockops ${DBNAME} ${master} > $output 2>&1
rc=$?

if [ $rc -ne 0 ]; then
    echo "gen_all_blockops exited with rc=$rc"
    cat $output
    exit 1
fi

diff $output expected

echo "All blockops processed successfully"
cat $output
exit 0
