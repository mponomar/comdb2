# Maintainer: Your Name <youremail@domain.com>
pkgname=comdb2
pkgver=7.0.0alpha
pkgrel=1
epoch=
pkgdesc="Bloomberg's Comdb2 RDBMS"
arch=('x86_64')
url="https://github.com/bloomberg/comdb2"
license=('custom')
groups=()
depends=()
makedepends=()
checkdepends=()
optdepends=()
provides=()
conflicts=()
replaces=()
backup=()
options=()
install=
changelog=
source=()
noextract=()
md5sums=()
validpgpkeys=()

# Not ready for _FORTIFY_SOURCE yet
CPPFLAGS=

prepare() {
    tar -c -C ../../../ --exclude=./distro/arch -f - . | tar -x -f -
}

build() {
	make -j$(nproc)
}

package() {
	make DESTDIR="$pkgdir/" install
}
